  "keyFeatures": [
    "Zap.md recipe files with YAML frontmatter defining provider pipelines",
    "CLI (`@wzrdtech/zap`) with init, new, validate, lint, run, status, and more",
    "Mock mode for zero-cost testing and live mode for real provider execution",
    "Multi-provider routing: GMI Cloud, fal, and BYOK secret types",
    "Budget enforcement: per-recipe cost caps enforced at CLI and web runtime",
    "Convex-backed run state with Upstash idempotency and poll queue",
    "Eve agent runtime with skill directories for AI-assisted recipe authoring",
    "HyperFrames stitching for HTML-composed video artifacts",
    "Wallet-authenticated BYOK provider secrets via Supabase"
  ],
  "publicApiSurface": [
    "zap init <dir>",
    "zap new <slug>",
    "zap validate [Zap.md]",
    "zap lint [Zap.md]",
    "zap run <Zap.md> [--live] [--input KEY=VALUE]",
    "zap status [runId]",
    "zap add <registry-name>",
    "zap docs [topic]",
    "zap skills [generate|update|check]",
    "zap doctor",
    "zap studio",
    "zap dev",
    "POST /api/zaps/run",
    "GET /api/skills",
    "GET /api/skills/[skill]",
    "POST /api/secrets",
    "POST /api/auth/wallet-proof",
    "parseZapMarkdown(markdown: string): ZapSpec",
    "planZapRun(zap: ZapSpec, extendCount: number): ZapPlan",
    "assertWithinBudget(plan: ZapPlan): void",
    "quoteStep(step: ZapStep): number",
    "expandRepeatSteps(zap: ZapSpec, extendCount: number): PlannedZapStep[]"
  ]
}
